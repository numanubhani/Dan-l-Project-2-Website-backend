# Copy to .env and fill in for production (e.g. PythonAnywhere).
# On PythonAnywhere, set these in Web → your app → "Environment variables" instead.

# Required in production (generate a new key, e.g. python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-secret-key-here

# Set to false on PythonAnywhere
DEBUG=False

# Your PythonAnywhere domain (comma-separated if multiple). Default in settings: muhammadnumansubhan1.pythonanywhere.com
ALLOWED_HOSTS=muhammadnumansubhan1.pythonanywhere.com

# On PythonAnywhere, set to your static directory (replace yourproject with your project folder name)
# STATIC_ROOT=/home/muhammadnumansubhan1/yourproject/static/

# Optional: frontend URL(s) for CORS, comma-separated
# CORS_EXTRA_ORIGINS=https://yourfrontend.pythonanywhere.com,https://yoursite.com
